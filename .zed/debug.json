// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Run & Debug native binary",
    "build": {
      "command": "cargo",
      "args": [
        "build",
      ],
      "cwd": "$ZED_WORKTREE_ROOT/test-game"
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/test-game",
    // sourceLanguages is required for CodeLLDB (not GDB) when using Rust
    "sourceLanguages": [
      "rust"
    ],
    "request": "launch",
    "adapter": "CodeLLDB",
    "cwd": "$ZED_WORKTREE_ROOT/test-game"
  }
]
